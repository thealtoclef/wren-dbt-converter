{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/thealtoclef/dbt-mdl/main/jsonschema/lineage.schema.json",
  "title": "Lineage Schema",
  "description": "Schema for lineage.json — a standalone lineage document that captures table-level and column-level data lineage.",

  "type": "object",
  "required": ["catalog", "schema", "dataSource", "tableLineage", "columnLineage"],
  "additionalProperties": false,

  "properties": {
    "$schema": {
      "description": "the schema of lineage",
      "type": "string",
      "const": "https://raw.githubusercontent.com/thealtoclef/dbt-mdl/main/jsonschema/lineage.schema.json"
    },
    "catalog": {
      "description": "Catalog name.",
      "type": "string"
    },

    "schema": {
      "description": "Schema name.",
      "type": "string"
    },

    "dataSource": {
      "description": "Data source type (e.g., BIGQUERY, SNOWFLAKE, POSTGRES).",
      "type": "string"
    },

    "tableLineage": {
      "description": "Table-level lineage edges. Each edge represents a data flow from a source model to a target model.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "additionalProperties": false,
        "properties": {
          "source": {
            "description": "The upstream (feeding) model name.",
            "type": "string",
            "minLength": 1
          },
          "target": {
            "description": "The downstream (consuming) model name.",
            "type": "string",
            "minLength": 1
          }
        }
      }
    },

    "columnLineage": {
      "description": "Column-level lineage edges.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "columns"],
        "additionalProperties": false,
        "properties": {
          "source": {
            "description": "The upstream (feeding) model name.",
            "type": "string",
            "minLength": 1
          },
          "target": {
            "description": "The downstream (consuming) model name.",
            "type": "string",
            "minLength": 1
          },
          "columns": {
            "description": "Column-level lineage mappings.",
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sourceColumn", "targetColumn", "lineageType"],
              "additionalProperties": false,
              "properties": {
                "sourceColumn": {
                  "description": "Column name in the source model.",
                  "type": "string",
                  "minLength": 1
                },
                "targetColumn": {
                  "description": "Column name in the target model. Empty for structural edges (filter/join/unknown).",
                  "type": "string",
                  "minLength": 0
                },
                "lineageType": {
                  "description": "Values: pass-through, rename, transformation, filter, join, unknown.",
                  "type": "string",
                  "enum": ["pass-through", "rename", "transformation", "filter", "join", "unknown"]
                }
              }
            }
          }
        }
      }
    }
  }
}
